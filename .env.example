# Database
# For local development, SQLite is used by default
# For production, use PostgreSQL
DATABASE_URL=sqlite:///./helix.db
# DATABASE_URL=postgresql://user:password@localhost:5432/helix

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800

# Google OAuth (get credentials at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://satyabio.com/api/oauth/google/callback

# Password Gate
GATE_PASSWORD=change-this-in-production
SECRET_KEY=

# Server
PORT=8000
